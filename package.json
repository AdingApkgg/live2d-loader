{
  "name": "live2d-loader",
  "private": true,
  "version": "0.0.0",
  "description": "A layered, pluggable Live2D loader with Web Component UI",
  "type": "module",
  "license": "MIT",
  "author": "AdingApkgg",
  "repository": {
    "type": "git",
    "url": "https://github.com/AdingApkgg/live2d-loader.git"
  },
  "homepage": "https://github.com/AdingApkgg/live2d-loader#readme",
  "bugs": "https://github.com/AdingApkgg/live2d-loader/issues",
  "scripts": {
    "dev": "pnpm --filter @live2d-loader/playground dev",
    "build": "pnpm -r --filter './packages/*' build",
    "lint": "TSESTREE_NO_WARN=true eslint packages/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "pnpm -r clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build && changeset publish"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  }
}
