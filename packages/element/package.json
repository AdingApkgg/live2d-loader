{
  "name": "@live2d-loader/element",
  "version": "0.1.1",
  "description": "Lit Web Components for Live2D loader — full UI with widget, dialog, toolbar",
  "license": "MIT",
  "author": "AdingApkgg",
  "repository": {
    "type": "git",
    "url": "https://github.com/AdingApkgg/live2d-loader.git",
    "directory": "packages/element"
  },
  "homepage": "https://github.com/AdingApkgg/live2d-loader#readme",
  "bugs": "https://github.com/AdingApkgg/live2d-loader/issues",
  "keywords": [
    "live2d",
    "web-component",
    "lit",
    "widget",
    "custom-element"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./autoload": {
      "types": "./dist/autoload.d.ts",
      "import": "./dist/autoload.js",
      "require": "./dist/autoload.cjs"
    }
  },
  "sideEffects": [
    "./dist/autoload.*",
    "./dist/index.*",
    "./src/autoload.ts",
    "./src/index.ts",
    "./src/live2d-model.ts",
    "./src/live2d-widget.ts"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@live2d-loader/core": "workspace:*",
    "@live2d-loader/renderer-webgl": "workspace:*",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
