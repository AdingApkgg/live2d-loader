{
  "name": "@live2d-loader/renderer-pixi",
  "version": "0.1.0",
  "description": "PixiJS 8 renderer for Live2D loader",
  "license": "MIT",
  "author": "AdingApkgg",
  "repository": {
    "type": "git",
    "url": "https://github.com/AdingApkgg/live2d-loader.git",
    "directory": "packages/renderer-pixi"
  },
  "homepage": "https://github.com/AdingApkgg/live2d-loader#readme",
  "bugs": "https://github.com/AdingApkgg/live2d-loader/issues",
  "keywords": [
    "live2d",
    "pixi",
    "pixijs",
    "renderer"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@live2d-loader/core": "workspace:*"
  },
  "peerDependencies": {
    "pixi.js": "^8.0.0"
  },
  "devDependencies": {
    "pixi.js": "^8.17.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
