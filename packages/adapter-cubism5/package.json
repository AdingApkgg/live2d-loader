{
  "name": "@live2d-loader/adapter-cubism5",
  "version": "0.1.0",
  "description": "Cubism 4/5 adapter for Live2D loader",
  "license": "MIT",
  "author": "AdingApkgg",
  "repository": {
    "type": "git",
    "url": "https://github.com/AdingApkgg/live2d-loader.git",
    "directory": "packages/adapter-cubism5"
  },
  "homepage": "https://github.com/AdingApkgg/live2d-loader#readme",
  "bugs": "https://github.com/AdingApkgg/live2d-loader/issues",
  "keywords": [
    "live2d",
    "cubism5",
    "cubism4",
    "cubism",
    "adapter",
    "moc3"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@live2d-loader/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
