{
  "name": "@live2d-loader/renderer-webgl",
  "version": "0.1.1",
  "description": "WebGL2 renderer for Live2D loader — zero external dependencies",
  "license": "MIT",
  "author": "AdingApkgg",
  "repository": {
    "type": "git",
    "url": "https://github.com/AdingApkgg/live2d-loader.git",
    "directory": "packages/renderer-webgl"
  },
  "homepage": "https://github.com/AdingApkgg/live2d-loader#readme",
  "bugs": "https://github.com/AdingApkgg/live2d-loader/issues",
  "keywords": [
    "live2d",
    "webgl",
    "webgl2",
    "renderer"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@live2d-loader/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
